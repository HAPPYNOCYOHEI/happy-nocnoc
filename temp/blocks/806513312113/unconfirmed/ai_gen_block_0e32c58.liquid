<script>
  (function() {
    class EditorialLayout{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const links = this.querySelectorAll('.ai-editorial-link-{{ ai_gen_id }}');
        links.forEach(link => {
          const title = link.querySelector('.ai-editorial-title-{{ ai_gen_id }}');
          if (title && !link.getAttribute('aria-label')) {
            link.setAttribute('aria-label', title.textContent.trim());
          }
        });
      }
    }

    customElements.define('editorial-layout-{{ ai_gen_id }}', EditorialLayout{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Magazine editorial layout",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_mobile",
      "label": "Padding mobile",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_desktop",
      "label": "Padding desktop",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Gap mobile",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "label": "Gap desktop",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        {
          "value": "1 / 1",
          "label": "Square"
        },
        {
          "value": "4 / 3",
          "label": "Landscape"
        },
        {
          "value": "3 / 4",
          "label": "Portrait"
        },
        {
          "value": "16 / 9",
          "label": "Wide"
        }
      ],
      "default": "4 / 3"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "category_size",
      "label": "Category size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "category_color",
      "label": "Category color",
      "default": "#191817"
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Title size mobile",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "label": "Title size desktop",
      "min": 18,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "feature_title_size_mobile",
      "label": "Feature title size mobile",
      "min": 20,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "feature_title_size_desktop",
      "label": "Feature title size desktop",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 42
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#191817"
    },
    {
      "type": "range",
      "id": "excerpt_size",
      "label": "Excerpt size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "excerpt_color",
      "label": "Excerpt color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "meta_size",
      "label": "Meta size",
      "min": 10,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "meta_color",
      "label": "Meta color",
      "default": "#999999"
    },
    {
      "type": "range",
      "id": "content_padding_mobile",
      "label": "Content padding mobile",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 15
    },
