{% doc %}
  @prompt
    杂志风格的社论布局
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-editorial-layout-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-editorial-layout-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_desktop }}px;
    }
  }

  .ai-editorial-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.gap_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-editorial-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(12, 1fr);
      gap: {{ block.settings.gap_desktop }}px;
    }
  }

  .ai-editorial-feature-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .ai-editorial-feature-{{ ai_gen_id }} {
      grid-column: span 8;
      grid-row: span 2;
    }
  }

  .ai-editorial-secondary-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .ai-editorial-secondary-{{ ai_gen_id }} {
      grid-column: span 4;
    }
  }

  .ai-editorial-tertiary-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .ai-editorial-tertiary-{{ ai_gen_id }} {
      grid-column: span 4;
    }
  }

  .ai-editorial-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-editorial-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-editorial-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-editorial-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
    opacity: 0.3;
  }

  .ai-editorial-content-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-editorial-content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding_desktop }}px;
    }
  }

  .ai-editorial-category-{{ ai_gen_id }} {
    font-size: {{ block.settings.category_size }}px;
    color: {{ block.settings.category_color }};
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 8px;
    display: block;
    font-weight: 600;
  }

  .ai-editorial-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size_mobile }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px 0;
    line-height: 1.2;
    font-weight: 700;
  }

  @media screen and (min-width: 750px) {
    .ai-editorial-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_desktop }}px;
    }
  }

  .ai-editorial-feature-{{ ai_gen_id }} .ai-editorial-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.feature_title_size_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-editorial-feature-{{ ai_gen_id }} .ai-editorial-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.feature_title_size_desktop }}px;
    }
  }

  .ai-editorial-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.excerpt_size }}px;
    color: {{ block.settings.excerpt_color }};
    line-height: 1.6;
    margin: 0 0 16px 0;
  }

  .ai-editorial-meta-{{ ai_gen_id }} {
    font-size: {{ block.settings.meta_size }}px;
    color: {{ block.settings.meta_color }};
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-editorial-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
    display: block;
    height: 100%;
  }

  .ai-editorial-link-{{ ai_gen_id }}:hover .ai-editorial-image-{{ ai_gen_id }} {
    transform: scale(1.05);
    transition: transform 0.6s ease;
  }

  .ai-editorial-image-{{ ai_gen_id }} {
    transition: transform 0.6s ease;
  }

  .ai-editorial-overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0) 100%);
    padding: {{ block.settings.content_padding_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-editorial-overlay-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding_desktop }}px;
    }
  }

  .ai-editorial-overlay-{{ ai_gen_id }} .ai-editorial-category-{{ ai_gen_id }},
  .ai-editorial-overlay-{{ ai_gen_id }} .ai-editorial-title-{{ ai_gen_id }},
  .ai-editorial-overlay-{{ ai_gen_id }} .ai-editorial-excerpt-{{ ai_gen_id }},
  .ai-editorial-overlay-{{ ai_gen_id }} .ai-editorial-meta-{{ ai_gen_id }} {
    color: #ffffff;
  }
{% endstyle %}

<editorial-layout-{{ ai_gen_id }} class="ai-editorial-layout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-editorial-grid-{{ ai_gen_id }}">
    <article class="ai-editorial-feature-{{ ai_gen_id }}">
      {% if block.settings.feature_link != blank %}
        <a href="{{ block.settings.feature_link }}" class="ai-editorial-link-{{ ai_gen_id }}">
      {% endif %}
        <div class="ai-editorial-image-wrapper-{{ ai_gen_id }}">
          {% if block.settings.feature_image %}
            <img
              src="{{ block.settings.feature_image | image_url: width: 1200 }}"
              alt="{{ block.settings.feature_image.alt | escape }}"
              class="ai-editorial-image-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ block.settings.feature_image.width }}"
              height="{{ block.settings.feature_image.height }}"
            >
          {% else %}
            <div class="ai-editorial-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
          {% if block.settings.feature_overlay %}
            <div class="ai-editorial-overlay-{{ ai_gen_id }}">
              {% if block.settings.feature_category != blank %}
                <span class="ai-editorial-category-{{ ai_gen_id }}">{{ block.settings.feature_category }}</span>
              {% endif %}
              {% if block.settings.feature_title != blank %}
                <h2 class="ai-editorial-title-{{ ai_gen_id }}">{{ block.settings.feature_title }}</h2>
              {% endif %}
              {% if block.settings.feature_excerpt != blank %}
                <p class="ai-editorial-excerpt-{{ ai_gen_id }}">{{ block.settings.feature_excerpt }}</p>
              {% endif %}
              {% if block.settings.feature_author != blank or block.settings.feature_date != blank %}
                <div class="ai-editorial-meta-{{ ai_gen_id }}">
                  {% if block.settings.feature_author != blank %}
                    <span>{{ block.settings.feature_author }}</span>
                  {% endif %}
                  {% if block.settings.feature_date != blank %}
                    <span>{{ block.settings.feature_date }}</span>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          {% endif %}
        </div>
        {% if block.settings.feature_overlay == false %}
          <div class="ai-editorial-content-{{ ai_gen_id }}">
            {% if block.settings.feature_category != blank %}
              <span class="ai-editorial-category-{{ ai_gen_id }}">{{ block.settings.feature_category }}</span>
            {% endif %}
            {% if block.settings.feature_title != blank %}
              <h2 class="ai-editorial-title-{{ ai_gen_id }}">{{ block.settings.feature_title }}</h2>
            {% endif %}
            {% if block.settings.feature_excerpt != blank %}
              <p class="ai-editorial-excerpt-{{ ai_gen_id }}">{{ block.settings.feature_excerpt }}</p>
            {% endif %}
            {% if block.settings.feature_author != blank or block.settings.feature_date != blank %}
              <div class="ai-editorial-meta-{{ ai_gen_id }}">
                {% if block.settings.feature_author != blank %}
                  <span>{{ block.settings.feature_author }}</span>
                {% endif %}
                {% if block.settings.feature_date != blank %}
                  <span>{{ block.settings.feature_date }}</span>
                {% endif %}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% if block.settings.feature_link != blank %}
        </a>
      {% endif %}
    </article>

