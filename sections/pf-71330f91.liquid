<script>
const LOOKBOOK_DATA = (() => {
  try { return JSON.parse(document.getElementById('lookbook-data')?.textContent || '{}'); }
  catch { return {}; }
})();

function applyLookbookTextAndProducts() {
  const looks = Array.from(document.querySelectorAll('.look'));
  const total = looks.length || 1;

  function inferProductCat(name) {
    const s = String(name || '').toLowerCase();
    if (/(t-?shirt|tee|半袖|tシャツ|ロングt|長袖|ノースリーブ)/i.test(s)) return 'TEE';
    if (/(パンツ|shorts|ショートパンツ|pants|ボトム)/i.test(s)) return 'PANTS';
    if (/(スカート|skirt)/i.test(s)) return 'SKIRT';
    if (/(ハット|hat|キャップ|cap)/i.test(s)) return 'HAT';
    if (/(バッグ|bag|リュック|backpack)/i.test(s)) return 'BAG';
    if (/(ジャケット|jacket|フーディ|hoodie|アウター|outer)/i.test(s)) return 'JACKET';
    if (/(サンダル|sandal|ブーツ|boot|スニーカー|sneaker|shoes)/i.test(s)) return 'SHOES';
    if (/(ソックス|socks)/i.test(s)) return 'SOCKS';
    return 'ITEM';
  }

  function simpleSceneEn(title) {
    const t = String(title || '').trim();
    if (!t) return 'everyday moments';
    const map = [
      [/春/, 'spring'], [/キャンプ/, 'camp'], [/冒険/, 'adventure'], [/森/, 'forest'],
      [/みどり/, 'green'], [/明る/, 'bright'], [/(おでかけ|出発)/, 'outing'],
      [/休日/, 'day off'], [/家族/, 'family time'], [/ぬくもり/, 'warm day'],
      [/寄り添/, 'close & gentle'], [/軽や/, 'light & easy'], [/外へ/, 'go outside'],
      [/元気/, 'full of energy'], [/自然/, 'nature'], [/風/, 'in the wind'],
      [/自由/, 'free'], [/心地/, 'comfortable'], [/整う/, 'fresh & simple'],
      [/弾け/, 'pop & play'], [/焚き火|bonfire/, 'bonfire'],
    ];
    const parts = [];
    const seen = new Set();
    for (const [re, w] of map) {
      if (re.test(t) && !seen.has(w)) { parts.push(w); seen.add(w); }
    }
    return parts.length ? parts.slice(0, 3).join(' · ') : 'everyday moments';
  }

  looks.forEach((look, idx) => {
    const key = `LOOK${idx + 1}`;
    const data = LOOKBOOK_DATA[key];

    const titleEl = look.querySelector('.look-title');
    if (titleEl && data?.title) titleEl.textContent = data.title;

    const sceneEl = look.querySelector('.look-scene-en');
    if (sceneEl) {
      const sceneText = String(data?.sceneEn || simpleSceneEn(data?.title))
        .replace(/\burban\b/gi, 'outgoing')
        .replace(/\bnight\b/gi, 'outdoor');
      sceneEl.textContent = sceneText;

      const catEl = look.querySelector('.look-cat');
      if (catEl) {
        const first = sceneText.split('·')[0]?.trim().split(/\s+/)[0]?.trim();
        if (first) catEl.textContent = first.toUpperCase();
      }
    }

    const fracEl = look.querySelector('.look-fraction');
    if (fracEl) fracEl.textContent = `${idx + 1}/${total}`;

    const productsEl = look.querySelector('.products');
    if (productsEl && Array.isArray(data?.products)) {
      productsEl.innerHTML = '';
      for (const p of data.products) {
        const a = document.createElement('a');
        a.className = 'product-line';
        a.href = p?.url || '#';
        if (a.getAttribute('href') === '#') a.addEventListener('click', e => e.preventDefault());

        const cat = document.createElement('span');
        cat.className = 'product-cat';
        cat.textContent = inferProductCat(p?.name).toUpperCase();

        const name = document.createElement('span');
        name.className = 'product-name';
        name.textContent = p?.name || '';

        const price = document.createElement('span');
        price.className = 'product-price';
        price.textContent = '';

        const dots = document.createElement('span');
        dots.className = 'product-dots';
        dots.setAttribute('aria-hidden', 'true');

        const buy = document.createElement('span');
        buy.className = 'buy';
        buy.textContent = 'Buy';

        a.append(cat, name, price, dots, buy);
        productsEl.appendChild(a);
      }
    }
  });

  document.querySelectorAll('.pager .dot').forEach(d => {
    const n = Number(d.dataset.dot);
    if (!Number.isFinite(n) || n >= looks.length) d.style.display = 'none';
  });
}

applyLookbookTextAndProducts();

function initCarousel(carEl) {
  const track    = carEl.querySelector('.carousel-track');
  const slides   = Array.from(carEl.querySelectorAll('.carousel-slide'));
  const carDots  = Array.from(carEl.querySelectorAll('.car-dot'));
  const n        = slides.length;
  let cur = 0;

  function getWidths() {
    const style    = getComputedStyle(document.documentElement);
    const centerW  = parseFloat(style.getPropertyValue('--center-w')) || 300;
    const sideW    = parseFloat(style.getPropertyValue('--side-w'))   || 120;
    const gap      = parseFloat(style.getPropertyValue('--gap-car'))  || 14;
    return { centerW, sideW, gap };
  }

  function applyLayout(activeIdx) {
    cur = ((activeIdx % n) + n) % n;

    slides.forEach((s, i) => {
      const isCenter = i === cur;
      s.classList.toggle('is-center', isCenter);
      s.classList.toggle('is-side',   !isCenter);
      const leftIdx  = ((cur - 1) + n) % n;
      const rightIdx = (cur + 1) % n;
      s.dataset.pos  = i === leftIdx ? 'left' : (i === rightIdx ? 'right' : 'center');
    });

    const { centerW, sideW, gap } = getWidths();
    const vpW = carEl.offsetWidth;

    const leftIdx  = ((cur - 1) + n) % n;
    const rightIdx = (cur + 1) % n;
    slides[leftIdx].style.order  = '1';
    slides[cur].style.order      = '2';
    slides[rightIdx].style.order = '3';

    slides[leftIdx].style.width  = sideW + 'px';
    slides[cur].style.width      = centerW + 'px';
    slides[rightIdx].style.width = sideW + 'px';

    const centerOfActive = sideW + gap + centerW / 2;
    const tx = vpW / 2 - centerOfActive;

    track.style.transform = `translateX(${tx}px)`;
    carDots.forEach((d, i) => d.classList.toggle('active', i === cur));
    carEl.dataset.active = String(cur);
  }

  carEl.querySelector('[data-car-dir="-1"]')?.addEventListener('click', () => applyLayout(cur - 1));
  carEl.querySelector('[data-car-dir="1"]')?.addEventListener('click',  () => applyLayout(cur + 1));
  carDots.forEach((d, i) => d.addEventListener('click', () => applyLayout(i)));

  let sx = 0, sy = 0;
  carEl.addEventListener('touchstart', e => { sx = e.touches[0].clientX; sy = e.touches[0].clientY; }, { passive: true });
  carEl.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - sx;
    const dy = e.changedTouches[0].clientY - sy;
    if (Math.abs(dx) < 30 || Math.abs(dx) < Math.abs(dy)) return;
    applyLayout(cur + (dx < 0 ? 1 : -1));
  }, { passive: true });

  window.addEventListener('resize', () => applyLayout(cur), { passive: true });
  applyLayout(1);
}

document.querySelectorAll('[data-carousel]').forEach(initCarousel);

const looks = Array.from(document.querySelectorAll('.look'));
const prefersReduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
let active = 0;

const io = new IntersectionObserver(entries => {
  for (const e of entries) {
    e.target.classList.toggle('in-view', e.isIntersecting);
  }
  const visible = entries.filter(e => e.isIntersecting);
  if (!visible.length) return;
  const best = visible.reduce((a,b) => a.intersectionRatio > b.intersectionRatio ? a : b);
  if (best.intersectionRatio > 0.4) {
    active = Number(best.target.dataset.index);
    document.querySelectorAll('.dot').forEach(d =>
      d.classList.toggle('active', Number(d.dataset.dot) === active));
    const tag = String(active + 1).padStart(2,'0');
    if (location.hash !== `#look-${tag}`) history.replaceState(null,'',`#look-${tag}`);
  }
}, { threshold: [0.1, 0.4, 0.7] });
looks.forEach(el => io.observe(el));

document.querySelectorAll('.pager .dot').forEach(d => {
  d.addEventListener('click', () => {
    looks[Number(d.dataset.dot)]?.scrollIntoView({ behavior: prefersReduce ? 'auto' : 'smooth', block: 'start' });
  });
});

function hexToRgb(hex) {
  const m = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec((hex||'').trim());
  return m ? { r:parseInt(m[1],16), g:parseInt(m[2],16), b:parseInt(m[3],16) } : {r:255,g:255,b:255};
}
function luminance({r,g,b}) {
  return [r,g,b].map(v => { const s=v/255; return s<=0.03928?s/12.92:Math.pow((s+0.055)/1.055,2.4); })
    .reduce((acc,v,i) => acc + v * [0.2126,0.7152,0.0722][i], 0);
}

looks.forEach(look => {
  const raw = (look.style.getPropertyValue('--bg')||'').trim();
  let bg = raw;
  if (raw.startsWith('var(')) {
    const varName = raw.match(/var\(([^)]+)\)/)?.[1];
    bg = getComputedStyle(document.documentElement).getPropertyValue(varName).trim();
  }
  const L = luminance(hexToRgb(bg));

  const layer = look.querySelector('.doodle-layer');
  if (!layer) return;
  const dc = L > 0.62 ? 'rgba(20,22,18,0.45)' : 'rgba(255,255,255,0.6)';
  const defs = [
    {kind:'circle',   x:'6%',  y:'12%', w:130, o:0.22},
    {kind:'mountain', x:'60%', y:'7%',  w:160, o:0.24},
    {kind:'river',    x:'64%', y:'66%', w:170, o:0.20},
    {kind:'grass',    x:'8%',  y:'68%', w:140, o:0.18},
    {kind:'tent',     x:'42%', y:'53%', w:120, o:0.19},
  ];
  defs.forEach(it => {
    const svg = document.createElementNS('http://www.w3.org/2000/svg','svg');
    svg.setAttribute('viewBox','0 0 120 120');
    svg.classList.add('doodle');
    const r = (Math.random()*14-7).toFixed(1);
    svg.style.cssText = `left:${it.x};top:${it.y};--dw:${it.w}px;--dh:${it.w}px;--do:${it.o};transform:rotate(${r}deg);`;
    let paths = '';
    if (it.kind==='circle')   paths='<circle cx="60" cy="60" r="38"/><circle cx="64" cy="56" r="40"/>';
    else if (it.kind==='mountain') paths='<path d="M10 92 L44 48 L62 70 L78 40 L110 92Z"/><path d="M44 48 L53 58 L62 70 M78 40 L86 52 L94 62"/>';
    else if (it.kind==='river')    paths='<path d="M10 70 C25 55,35 85,50 70 S75 55,90 70 S105 85,110 70"/><path d="M10 86 C25 71,35 101,50 86 S75 71,90 86 S105 101,110 86"/>';
    else if (it.kind==='grass')    paths='<path d="M14 92 C18 70,26 72,28 54 C30 76,38 74,40 52 C42 76,50 74,54 56 C56 80,64 78,66 54 C68 78,78 78,80 58 C82 82,94 80,98 60 C100 76,104 78,106 92"/>';
    else if (it.kind==='tent')     paths='<path d="M18 92 L60 28 L102 92Z"/><path d="M60 28 L60 92"/><path d="M55 92 L55 74 C55 68,65 68,65 74 L65 92"/>';
    svg.innerHTML = paths;
    svg.querySelectorAll('path,circle').forEach(el => {
      el.setAttribute('stroke', dc);
      el.setAttribute('stroke-width','2.5');
      el.setAttribute('fill','transparent');
      el.setAttribute('stroke-linecap','round');
      el.setAttribute('stroke-linejoin','round');
    });
    layer.appendChild(svg);
  });
});

if (/^#look-\d\d$/.test(location.hash)) {
  const n = Number(location.hash.slice(-2));
  if (!isNaN(n) && n >= 1 && n <= looks.length)
    requestAnimationFrame(() => looks[n-1]?.scrollIntoView({behavior:'auto',block:'start'}));
}
</script>
