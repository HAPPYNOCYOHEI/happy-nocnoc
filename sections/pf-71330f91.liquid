  font-size: 11px;
  letter-spacing: 0.2em;
  font-weight: 600;
  border: 1px solid currentColor;
  padding: 1px 6px;
  opacity: 0.72;
  text-transform: uppercase;
}
.look-scene-en {
  font-family: var(--ff-mono);
  font-size: 11px;
  letter-spacing: 0.1em;
  font-style: italic;
  opacity: 0.5;
}
.look-title {
  font-family: var(--ff-title);
  font-weight: 500;
  font-size: clamp(25px, 4.2vw, 47px);
  line-height: 1.1;
  letter-spacing: 0.02em;
  margin-bottom: clamp(16px, 2.4vw, 26px);
  color: var(--titleFill, rgba(20,22,18,0.9));
  -webkit-font-smoothing: none;
  font-smooth: never;
  text-rendering: optimizeSpeed;
  position: relative;
}
.products {
  display: grid;
  gap: clamp(8px, 1vw, 12px);
}
.product-line {
  display: flex;
  align-items: baseline;
  gap: 6px;
  text-decoration: none;
  color: inherit;
  min-width: 0;
  transition: opacity 0.18s ease;
}
.product-line:hover { opacity: 0.7; }
.product-cat {
  font-family: var(--ff-product);
  font-weight: 700;
  font-size: 10px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  white-space: nowrap;
  flex: 0 0 auto;
}
.product-name {
  font-family: var(--ff-product);
  font-size: clamp(11px, 1.1vw, 13px);
  font-weight: 400;
  letter-spacing: 0.02em;
  white-space: nowrap;
  overflow: visible;
  text-overflow: clip;
  opacity: 0.9;
  flex: 0 1 auto;
  min-width: 0;
}
.product-price {
  font-family: var(--ff-product);
  font-size: 11px;
  letter-spacing: 0.06em;
  white-space: nowrap;
  opacity: 0.78;
  flex: 0 0 auto;
}
.product-dots {
  flex: 1;
  border-bottom: 1px dashed rgba(20,22,18,0.3);
  transform: translateY(-3px);
  min-width: 8px;
  max-width: 28px;
}
.buy {
  font-family: var(--ff-product);
  font-size: 10px;
  letter-spacing: 0.1em;
  padding: 4px 9px 3px;
  border: 1.5px solid var(--buyInk, rgba(20,22,18,0.75));
  color: var(--buyInk, rgba(20,22,18,0.75));
  background: transparent;
  cursor: pointer;
  transition: background 0.18s ease, color 0.18s ease;
  flex: 0 0 auto;
  text-transform: uppercase;
}
.product-line:hover .buy {
  background: var(--buyInk, rgba(20,22,18,0.75));
  color: var(--buyFill, #fff);
}
.pager { margin-top: clamp(12px, 2vw, 20px); }
.dots { display: inline-flex; gap: 8px; align-items: center; }
.dot {
  width: 8px; height: 8px;
  border-radius: 999px;
  border: 1.5px solid rgba(20,22,18,0.4);
  background: transparent;
  cursor: pointer;
  transition: background 0.2s, border-color 0.2s;
}
.dot.active { background: rgba(20,22,18,0.8); border-color: rgba(20,22,18,0.8); }
.look-right {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  order: 2;
  overflow: hidden;
  z-index: 1;
}
.carousel {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  display: flex;
  align-items: center;
}
.carousel-track {
  display: flex;
  align-items: center;
  height: 100%;
  gap: var(--gap-car);
  transition: transform 380ms cubic-bezier(0.4,0,0.2,1);
  will-change: transform;
  transform: translateX(var(--track-x, 0px));
}
.carousel-slide {
  flex: 0 0 auto;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 380ms cubic-bezier(0.4,0,0.2,1), opacity 380ms ease;
}
.carousel-slide.is-side {
  width: var(--side-w);
  opacity: 0.55;
}
.carousel-slide.is-center {
  width: var(--center-w);
  opacity: 1;
  z-index: 2;
}
.tilt-card {
  aspect-ratio: 2 / 3;
  width: 100%;
  height: auto;
  max-height: 78dvh;
  background: transparent;
  border: none;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border-radius: 8px;
  transition: transform 380ms cubic-bezier(0.4,0,0.2,1);
}
.carousel-slide.is-center .tilt-card {
  transform: rotate(0deg);
  box-shadow: 0 12px 48px rgba(0,0,0,0.18);
}
.carousel-slide.is-side:first-child .tilt-card,
.carousel-slide[data-pos="left"] .tilt-card {
  transform: rotate(-8deg) translateX(-10px);
}
.carousel-slide.is-side:last-child .tilt-card,
.carousel-slide[data-pos="right"] .tilt-card {
  transform: rotate(8deg) translateX(10px);
}
.tilt-card img {
  width: 100%; height: 100%;
  object-fit: cover;
  object-position: center top;
  transition: transform 0.4s ease;
  display: block;
}
.carousel-slide.is-center .tilt-card img { transform: scale(1.03); }
.carousel-slide.is-side .tilt-card img { transform: scale(1.0); }
.car-arrow {
  position: absolute;
  top: 50%; transform: translateY(-50%);
  width: 36px; height: 36px;
  display: grid; place-items: center;
  border: 1px solid rgba(255,255,255,0.5);
  color: rgba(255,255,255,0.9);
  background: rgba(0,0,0,0.1);
  cursor: pointer;
  font-size: 20px;
  line-height: 1;
  transition: background 0.18s;
  z-index: 5;
}
.car-arrow:hover { background: rgba(0,0,0,0.24); }
.car-arrow.prev { left: 10px; }
.car-arrow.next { right: 10px; }
.car-dots {
  position: absolute;
  left: 50%; bottom: 16px;
  transform: translateX(-50%);
  display: inline-flex;
  gap: 8px;
  z-index: 5;
}
.car-dot {
  width: 8px; height: 8px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.65);
  background: transparent;
  cursor: pointer;
  transition: background 0.2s;
}
.car-dot.active { background: rgba(255,255,255,0.95); border-color: rgba(255,255,255,0.95); }
.doodle-layer {
  position: absolute; inset: 0;
  pointer-events: none; z-index: 0; overflow: hidden;
}
.doodle {
  position: absolute;
  width: var(--dw, 120px); height: var(--dh, 120px);
  opacity: var(--do, 0.25);
}
.doodle path, .doodle circle {
  stroke: var(--dc, rgba(20,22,18,0.65));
  stroke-width: 2.5; fill: transparent;
  stroke-linecap: round; stroke-linejoin: round;
}
